generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")

  // Para SQLite em desenvolvimento/testes:
  // provider = "sqlite"
  // url      = "file:./dev.db"
}

model User {
  id         Int      @id @default(autoincrement())
  nome       String
  email      String   @unique
  senha      String
  id_perfil  Int      @unique
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  profile Profile @relation(fields: [id_perfil], references: [id])

  @@map("users")
}

model Profile {
  id          Int    @id @default(autoincrement())
  perfil_nome String

  user User?

  @@map("profiles")
}

